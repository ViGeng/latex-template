%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% PACKAGE DEPENDENCIES
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage{xcolor}      % For colored text and backgrounds
\RequirePackage{pifont}      % For symbols (checkmarks, etc.)
\RequirePackage{enumitem}    % For customized lists
\RequirePackage{xparse}      % For advanced command definitions
\RequirePackage{ifthen}      % For conditional statements
\RequirePackage{mdframed}    % For framed boxes and environments

% Avoid duplicate-definition of \Bbbk when other packages (e.g. newtx/math)
% are loaded by the document class. Relax the command before loading amssymb.
\let\Bbbk\relax
\RequirePackage{amssymb}     % For mathematical symbols
% Formatting and number handling for aligned numeric output
\RequirePackage{siunitx}
\sisetup{round-mode=places,round-precision=2}

% hyperref + cleveref. hyperref must be loaded after most packages and before
% cleveref, so we manage that ordering here. Override settings in your project
% preamble with \hypersetup{...} after \usepackage{custom}.
\RequirePackage{hyperref}
\RequirePackage{cleveref}
\crefname{figure}{Fig.}{Figs.}        \Crefname{figure}{Fig.}{Figs.}
\crefname{table}{Tab.}{Tabs.}         \Crefname{table}{Tab.}{Tabs.}
\crefname{equation}{Eq.}{Eqs.}        \Crefname{equation}{Eq.}{Eqs.}
\crefname{section}{\S}{\S\S}          \Crefname{section}{\S}{\S\S}
\crefname{subsection}{\S}{\S\S}       \Crefname{subsection}{\S}{\S\S}
\crefname{subsubsection}{\S}{\S\S}    \Crefname{subsubsection}{\S}{\S\S}
\crefname{appendix}{App.}{Apps.}      \Crefname{appendix}{App.}{Apps.}
\crefname{algorithm}{Alg.}{Algs.}     \Crefname{algorithm}{Alg.}{Algs.}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% VISUAL INDICATORS AND SYMBOLS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Simple green checkmark for general use
% Usage: \gcheck
\newcommand{\gcheck}{\textcolor{green}{\ding{51}}}

% Table helper for percentage changes
% Usage:
%   \change{1.22}{+}           normal size
%   \change{1.22}{+}{}         normal size (same as above)
%   \change{1.22}{+}{-}        noting style (smaller, lighter)
%   \change{1.22}{+}{+}        stressing style (bold)
% Sign argument:
%   + : green up triangle (increase)
%   - : red down triangle (decrease)
%   0 : gray "=" symbol (no change)
\NewDocumentCommand{\change}{m m G{}}{%
  % Resolve style: size + bold wrapper + fade suffix
  \ifthenelse{\equal{#3}{-}}%
    {\def\change@sz{\scriptsize}\let\change@wrap\relax\def\change@fade{!60!white}}%
    {\ifthenelse{\equal{#3}{+}}%
      {\let\change@sz\relax\def\change@wrap##1{\textbf{\uline{##1}}}\def\change@fade{}}%
      {\let\change@sz\relax\let\change@wrap\relax\def\change@fade{}}%
    }%
  \ifthenelse{\equal{#2}{+}}%
    {\def\change@col{green!55!black\change@fade}\def\change@sym{$\blacktriangle$}}%
    {\ifthenelse{\equal{#2}{-}}%
      {\def\change@col{red!70!black\change@fade}\def\change@sym{$\blacktriangledown$}}%
      {\def\change@col{black!45!white\change@fade}\def\change@sym{$=$}}%
    }%
  \ifthenelse{\equal{#1}{}}%
    {{\textcolor{\change@col}{\change@sz\change@wrap{\raisebox{0.3ex}{\tiny\change@sym}}}}}%
    {{\textcolor{\change@col}{\change@sz\change@wrap{\num{#1}\%}\raisebox{0.3ex}{\tiny\change@sym}}}}%
}
\newcommand{\improved}[1]{\change{#1}{+}}

% Colored symbols for task lists
\newcommand{\cmark}{\textcolor{teal}{\ding{51}}}    % Completed task marker
\newcommand{\xmark}{\textcolor{red}{\ding{55}}}     % Won't fix task marker

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% TODO LISTS AND TASK MANAGEMENT
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Todo list environment with checkboxes.
% Usage:
%   \begin{todolist}
%     \item            open task
%     \item[\done]     completed task
%     \item[\wontfix]  task that won't be completed
%     \item[\wip]      work in progress
%   \end{todolist}
% Markers share a fixed-width box so labels align across all states.
\newcommand{\todo@box}[1]{\makebox[1.1em][l]{\raisebox{0.1ex}{$\square$}\llap{\raisebox{0.35ex}{\hspace{0.18em}#1}\hspace{0.25em}}}}
\newcommand{\done}{\todo@box{\textcolor{teal}{\footnotesize\ding{51}}}}
\newcommand{\wontfix}{\todo@box{\textcolor{red}{\footnotesize\ding{55}}}}
\newcommand{\wip}{\todo@box{\textcolor{orange!80!black}{\footnotesize$\bullet$}}}

\newlist{todolist}{itemize}{2}
\setlist[todolist]{label=\todo@box{},
  leftmargin=1.6em, labelsep=0.4em,
  topsep=2pt, partopsep=0pt, parsep=0pt, itemsep=2pt}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% TEXT HIGHLIGHTING AND ANNOTATIONS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Highlight uncertain text with optional custom footnote
% Usage: \unsure{uncertain text}[optional footnote text]
% Note: Uses only color and bold for natural line breaking
\NewDocumentCommand{\unsure}{m o}{%
    \textbf{\textcolor{orange}{#1}}%
    \footnote{\textcolor{red}{%
        \IfValueTF{#2}{#2}{Unsure wording, please finalize.}%
    }}%
}

% Placeholder command for content to be inserted later
% Usage: \placeholder{description of what goes here}
% Creates a distinct boxed placeholder that respects text width
\newcommand{\placeholder}[1]{%
    \noindent\fcolorbox{orange}{orange!10}{%
        \parbox{\dimexpr\linewidth-2\fboxsep-2\fboxrule}{%
            \textbf{\textcolor{orange}{[PLACEHOLDER: #1]}}%
        }%
    }%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% COMMENT SYSTEM
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Toggle for showing/hiding comments in the document
\newboolean{showcomments}
\setboolean{showcomments}{true}

% Generic comment command with author name and color
% Usage: \mynote{AuthorName}{comment text}{color}
\ifthenelse{\boolean{showcomments}}
{ \newcommand{\mynote}[3]{%
   \protect\fbox{\bfseries\sffamily\scriptsize#1}%
   {\small$\triangleright$\textsf{\color{#3}{#2}}$\triangleleft$}}} 
{ \newcommand{\mynote}[3]{}}%

% Predefined comment command for Wei
% Usage: \wei{comment text}
\newcommand{\wei}[1]{\mynote{Wei}{#1}{blue}}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% BOXED CONTENT AND QUOTATIONS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Gray box environment for quotations and highlighted content
\newmdenv[
  backgroundcolor=gray!20,
  linewidth=0pt,
  innerleftmargin=5pt,
  innerrightmargin=5pt,
  innertopmargin=5pt,
  innerbottommargin=5pt
]{graybox}

% Command wrapper for gray box content
% Usage: \grayboxtext{your text here}
\newcommand{\grayboxtext}[1]{%
  \begin{graybox}
    #1
  \end{graybox}
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% CONCEPT INTRODUCTION COMMAND
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Structured command to introduce concepts in academic writing
% Creates a labeled textbox followed by framed content
% Usage: \say[concept name]{main explanatory text}
% Example: \say[Key Insight]{This is the main idea we want to convey.}
%
% Visual format: [concept name] ⌜ main text ⌝
% - Concept name appears in a gray background box with sans-serif font
% - Main text is framed with mathematical corner symbols
% - Subtle gray coloring for professional appearance
\NewDocumentCommand{\say}{O{Concept} m}{%
  \colorbox{gray!15}{\scriptsize\textbf{\textsf{\textcolor{gray!70}{#1}}}}~\textcolor{gray!60}{$\ulcorner$}~#2~\textcolor{gray!60}{$\lrcorner$}%
}

