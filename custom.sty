%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% custom.sty - Custom LaTeX commands and environments for academic writing
% v0.6  2026/06/07
% Author: Wei
%
% USAGE
%   \usepackage{custom}                 % in your project preamble
%   \hypersetup{colorlinks=true, ...}   % optional, AFTER the line above
%
% LOAD ORDER
%   custom.sty pulls in hyperref + cleveref itself, so do NOT load hyperref in
%   your preamble. Apply hyperref options with \hypersetup{} after \usepackage.
%
% QUICK REFERENCE
%   Symbols & indicators
%     \gcheck                          green checkmark
%     \cmark, \xmark                   teal check, red cross
%   Numeric change indicator
%     \change{pct}{sign}[{style}]      manual percentage change
%     \change[old,new][{}{}{style}]    auto-computed from two values
%     \improved{pct}                   shorthand for \change{pct}{+}
%   Todo lists
%     \begin{todolist}...\end{todolist}  items: \item[\done|\wip|\wontfix]
%   Inline annotations
%     \unsure{text}[footnote]          orange bold + footnote
%     \ph{hint}                        inline placeholder [hint?]
%   Collaboration & review (all hidden when showcomments=false)
%     \wei{text}                       inline note tagged "Wei"
%     \mynote{author}{text}{color}     generic author note
%     \todo[label]{text}               action item; label sets priority colour
%                                      (FIXME/BUG red, TODO orange, NOTE/LATER gray)
%     \ai[state]{text}{instruction}    quote a span + a prompt for an AI; [hold] parks it
%   Boxes & structure
%     \begin{graybox}...\end{graybox}, \grayboxtext{...}
%     \say[concept]{text}              labelled concept introduction
%   Cross-references (cleveref)
%     \cref{label}, \Cref{label}       Fig./Tab./Eq./§/App./Alg. abbreviations
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{custom}[2026/06/07 v0.6 Custom LaTeX helpers for academic writing]

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% PACKAGE DEPENDENCIES
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage{xcolor}      % colored text and backgrounds
\RequirePackage{pifont}      % dingbat symbols (checkmarks, crosses)
\RequirePackage{fontawesome5}% message / status icons (\ai chat bubbles)
\RequirePackage{enumitem}    % customised list environments (todolist)
\RequirePackage{xparse}      % \NewDocumentCommand with rich arg specs
\RequirePackage{ifthen}      % \ifthenelse / \equal for branching
\RequirePackage{mdframed}    % framed environments (graybox)

% amssymb conflicts with newtxmath / fourier / etc. on \Bbbk. Relax it first
% so loading order with the document class doesn't matter.
\let\Bbbk\relax
\RequirePackage{amssymb}     % $\blacktriangle$, $\blacktriangledown$, $\square$

% siunitx: aligned numeric output. Default to 2 decimal places so \change shows
% e.g. "5.00%" instead of raw "5". Override per-document with \sisetup{...}.
\RequirePackage{siunitx}
\sisetup{round-mode=places,round-precision=2}

\RequirePackage{xfp}         % \fpeval — used by auto-computed \change[old,new]

% hyperref + cleveref. hyperref must come after most packages and before
% cleveref. Loading them here removes a load-order footgun for callers; apply
% project-specific options with \hypersetup{...} AFTER \usepackage{custom}.
\RequirePackage{hyperref}
\RequirePackage{cleveref}

% Abbreviated cross-reference names — saves space and keeps a consistent style.
% Both \cref (lowercase) and \Cref (sentence-start) variants.
\crefname{figure}{Fig.}{Figs.}        \Crefname{figure}{Fig.}{Figs.}
\crefname{table}{Tab.}{Tabs.}         \Crefname{table}{Tab.}{Tabs.}
\crefname{equation}{Eq.}{Eqs.}        \Crefname{equation}{Eq.}{Eqs.}
\crefname{section}{\S}{\S\S}          \Crefname{section}{\S}{\S\S}
\crefname{subsection}{\S}{\S\S}       \Crefname{subsection}{\S}{\S\S}
\crefname{subsubsection}{\S}{\S\S}    \Crefname{subsubsection}{\S}{\S\S}
\crefname{appendix}{App.}{Apps.}      \Crefname{appendix}{App.}{Apps.}
\crefname{algorithm}{Alg.}{Algs.}     \Crefname{algorithm}{Alg.}{Algs.}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% SYMBOLS & INDICATORS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% \gcheck — green checkmark for inline use, e.g. "\gcheck done".
\newcommand{\gcheck}{\textcolor{green}{\ding{51}}}

% \cmark / \xmark — colored check and cross used inline or in tables.
\newcommand{\cmark}{\textcolor{teal}{\ding{51}}}
\newcommand{\xmark}{\textcolor{red}{\ding{55}}}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% NUMERIC CHANGE INDICATOR
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% \change — percentage-change indicator with sign symbol and color.
%
%   Manual:  \change{1.22}{+}        pct + sign, normal size
%            \change{1.22}{+}{-}     noting style (smaller, faded)
%            \change{1.22}{+}{+}     stressing style (bold)
%   Auto:    \change[100,105]        -> 5.00% ▲   (pct & sign from old,new)
%            \change[200,180]{}{}{+} -> 10.00% ▼  (stressing)
%            \change[50,50]          -> 0.00% =
%
%   sign:  +  green up ▲   |  -  red down ▼   |  0  gray =
%   style: (empty) normal  |  -  noting (\scriptsize, faded)  |  +  stressing (bold)
%
% Caveats: old=0 in [old,new] divides by zero in \fpeval (guard at source);
% use a single comma in [old,new]. Output is wrapped in {} so style/color do
% not leak into surrounding text.
\def\change@split#1,#2\change@end{\def\change@old{#1}\def\change@new{#2}}
\NewDocumentCommand{\change}{O{} G{} G{} G{}}{%
  % Defaults: take pct/sign from manual args; auto-mode overrides below.
  \def\change@pct{#2}\def\change@sgn{#3}%
  \ifthenelse{\equal{#1}{}}{}{%
    % Auto mode: split [old,new], compute signed comparison and absolute pct.
    \change@split#1\change@end
    \edef\change@cmp{\fpeval{sign((\change@new)-(\change@old))}}%
    \edef\change@pct{\fpeval{round(abs((\change@new)-(\change@old))/(\change@old)*100,2)}}%
    \ifnum\change@cmp=1\relax\def\change@sgn{+}\fi
    \ifnum\change@cmp=0\relax\def\change@sgn{0}\fi
    \ifnum\change@cmp=-1\relax\def\change@sgn{-}\fi
  }%
  % Resolve style: size macro, content wrapper, and color-fade suffix.
  \ifthenelse{\equal{#4}{-}}%
    {\def\change@sz{\scriptsize}\let\change@wrap\relax\def\change@fade{!60!white}}%
    {\ifthenelse{\equal{#4}{+}}%
      {\let\change@sz\relax\let\change@wrap\textbf\def\change@fade{}}%
      {\let\change@sz\relax\let\change@wrap\relax\def\change@fade{}}%
    }%
  % Resolve sign-dependent color and triangle/equals symbol.
  \ifthenelse{\equal{\change@sgn}{+}}%
    {\def\change@col{green!55!black\change@fade}\def\change@sym{$\blacktriangle$}}%
    {\ifthenelse{\equal{\change@sgn}{-}}%
      {\def\change@col{red!70!black\change@fade}\def\change@sym{$\blacktriangledown$}}%
      {\def\change@col{black!45!white\change@fade}\def\change@sym{$=$}}%
    }%
  % Render. Empty pct -> symbol only; otherwise number%-then-symbol.
  \ifthenelse{\equal{\change@pct}{}}%
    {{\textcolor{\change@col}{\change@sz\change@wrap{\raisebox{0.3ex}{\tiny\change@sym}}}}}%
    {{\textcolor{\change@col}{\change@sz\change@wrap{\num{\change@pct}\%}\raisebox{0.3ex}{\tiny\change@sym}}}}%
}

% \improved{pct} — shorthand for an unconditional positive change.
\newcommand{\improved}[1]{\change{#1}{+}}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% TODO LISTS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Checklist with a consistent set of FontAwesome circle markers. Every state
% uses an icon of the same size dropped into one fixed-width box, so the task
% text lines up perfectly regardless of marker.
%
%   \begin{todolist}
%     \item            open task     (hollow circle)
%     \item[\done]     completed     (teal check)
%     \item[\wip]      in progress   (orange dot)
%     \item[\wontfix]  abandoned     (red cross)
%   \end{todolist}
\newcommand{\td@mark}[1]{\makebox[1.2em][c]{\small#1}}
\newcommand{\done}{\td@mark{\textcolor{teal}{\faCheckCircle}}}
\newcommand{\wip}{\td@mark{\textcolor{orange!90!black}{\faDotCircle}}}
\newcommand{\wontfix}{\td@mark{\textcolor{red!80!black}{\faTimesCircle}}}

\newlist{todolist}{itemize}{2}
\setlist[todolist]{label=\td@mark{\textcolor{black!40}{\faCircle[regular]}},
  leftmargin=2em, labelsep=0.5em,
  topsep=3pt, partopsep=0pt, parsep=0pt, itemsep=3pt}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% INLINE ANNOTATIONS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% \unsure{text}[footnote] — flag wording you are not yet confident in. Renders
% the text as bold orange with a red footnote (default: "Unsure wording, please
% finalize.").
\NewDocumentCommand{\unsure}{m o}{%
    \textbf{\textcolor{orange}{#1}}%
    \footnote{\textcolor{red}{%
        \IfValueTF{#2}{#2}{Unsure wording, please finalize.}%
    }}%
}

% \ph{hint} — inline placeholder for an unmeasured number, undecided name, or
% any token to fill in before submission. Renders as [hint?] in muted orange:
% reads cleanly in body text but is easy to grep / scan. Empty arg: \ph{} -> [?].
\newcommand{\ph}[1]{%
    \textcolor{orange!85!black}{%
        [\ifthenelse{\equal{#1}{}}{\textbf{?}}{#1\textsuperscript{\textbf{?}}}]%
    }%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% COLLABORATION & REVIEW
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Master toggle for every review annotation below. Set to false before
% camera-ready submission to strip all of them from the output.
\newboolean{showcomments}
\setboolean{showcomments}{true}

% \mynote{author}{text}{color} — boxed author tag followed by a colored comment.
% Wrap it to make per-author shorthands (see \wei).
\ifthenelse{\boolean{showcomments}}
{ \newcommand{\mynote}[3]{%
   \protect\fbox{\bfseries\sffamily\scriptsize#1}%
   {\small$\triangleright$\textsf{\color{#3}{#2}}$\triangleleft$}}}
{ \newcommand{\mynote}[3]{}}%

% \wei{text} — shorthand for \mynote{Wei}{...}{blue}.
\newcommand{\wei}[1]{\mynote{Wei}{#1}{blue}}

% \todo[label]{text} — inline action item, distinct from \wei (an author
% comment): flag work that still needs doing. The label sets both the tag and
% a priority colour:
%   FIXME, BUG      high    (red)
%   TODO (default)  normal  (orange)
%   NOTE, LATER     low     (gray)
% any other label renders in the normal colour. Shown as a filled tag followed
% by the item in the same colour. Add cases to the branch for more priorities.
\ifthenelse{\boolean{showcomments}}
{ \NewDocumentCommand{\todo}{O{TODO} m}{%
    \ifthenelse{\equal{#1}{FIXME} \OR \equal{#1}{BUG}}%
      {\def\todo@col{red!85!black}}%
      {\ifthenelse{\equal{#1}{NOTE} \OR \equal{#1}{LATER}}%
        {\def\todo@col{black!55}}%
        {\def\todo@col{orange!90!black}}}%
    \protect\colorbox{\todo@col}{\bfseries\sffamily\scriptsize\textcolor{white}{#1}}%
    {\small~\textsf{\textcolor{\todo@col}{#2}}}}}
{ \NewDocumentCommand{\todo}{O{TODO} m}{}}%

% \ai[state]{quoted text}{instruction} — hand a span of text to an AI
% collaborator with an instruction. The quoted span is bracketed and followed
% by a chat-bubble carrying the instruction, so it reads as a prompt addressed
% to the AI. The optional [state] says what the AI should do with it:
%   (default)  act  — apply / fix this now   (violet, filled bubble)
%   hold       park — leave it, do not act    (gray, hollow bubble + "hold")
% The quoted text always stays in the document; the bubble and instruction
% disappear when showcomments is off. Extend by adding cases to the branch.
\NewDocumentCommand{\ai}{O{} m m}{%
  \ifthenelse{\boolean{showcomments}}{%
    \ifthenelse{\equal{#1}{hold}}%
      {\def\ai@col{black!55}\def\ai@icon{\faComment[regular]}\def\ai@lab{\,\textsf{\scriptsize hold}}}%
      {\def\ai@col{violet}\def\ai@icon{\faCommentDots}\def\ai@lab{}}%
    \textcolor{\ai@col}{[}#2\textcolor{\ai@col}{]}%
    \,\textcolor{\ai@col}{\ai@icon\ai@lab\,\textsf{#3}}%
  }{#2}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% BOXES & STRUCTURE
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% graybox — block-level light-gray background, no border. Use the environment
% for multi-paragraph content; use \grayboxtext{...} as a one-shot wrapper.
\newmdenv[
  backgroundcolor=gray!20,
  linewidth=0pt,
  innerleftmargin=5pt,
  innerrightmargin=5pt,
  innertopmargin=5pt,
  innerbottommargin=5pt
]{graybox}

\newcommand{\grayboxtext}[1]{%
  \begin{graybox}
    #1
  \end{graybox}
}

% \say[concept]{text} — labelled concept introduction for structured writing.
% Renders as  [concept] ⌜ text ⌝ : a gray sans-serif tag plus corner-delimited
% body. Mark each conceptual unit (background, motivation, method, ...) so the
% reader can scan a paragraph's structure quickly.
%
%   \say[Background]{Prior work focused on ...}
%   \say{Concept}{Default tag if you omit the optional name.}
\NewDocumentCommand{\say}{O{Concept} m}{%
  \colorbox{gray!15}{\scriptsize\textbf{\textsf{\textcolor{gray!70}{#1}}}}~\textcolor{gray!60}{$\ulcorner$}~#2~\textcolor{gray!60}{$\lrcorner$}%
}

